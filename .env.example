# Dialpad API
DIALPAD_API_KEY=your_dialpad_api_key_here
DIALPAD_WEBHOOK_SECRET=your_webhook_secret_here
DIALPAD_API_BASE_URL=https://sandbox.dialpad.com/api/v2

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://dialpad:dialpad@localhost:5432/dialpad_calls

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
